<script>
// ============================================
// STATE
// ============================================
let mediaRecorder = null;
let audioChunks = [];
let analyser = null;
let animFrameId = null;
let isRecording = false;
let audioCtx = null;
let stream = null;

// ============================================
// TABS
// ============================================
function switchTab(name) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  event.target.classList.add('active');
}

// ============================================
// STATUS
// ============================================
function setStatus(text, type = 'idle') {
  document.getElementById('statusText').textContent = text;
  const dot = document.getElementById('statusDot');
  dot.className = 'status-dot';
  if (type === 'active') dot.classList.add('red');
  else if (type === 'thinking') dot.style.background = '#ffaa00';
}

// ============================================
// WAVE VISUALIZER
// ============================================
function startVisualizer(stream) {
  const canvas = document.getElementById('waveCanvas');
  const ctx = canvas.getContext('2d');
  canvas.width = canvas.offsetWidth;
  canvas.height = canvas.offsetHeight;

  audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  const source = audioCtx.createMediaStreamSource(stream);
  analyser = audioCtx.createAnalyser();
  analyser.fftSize = 256;
  source.connect(analyser);

  const bufferLength = analyser.frequencyBinCount;
  const dataArray = new Uint8Array(bufferLength);

  function draw() {
    animFrameId = requestAnimationFrame(draw);
    analyser.getByteFrequencyData(dataArray);

    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = 'rgba(5,5,3,0)';

    const barW = (canvas.width / bufferLength) * 2.5;
    let x = 0;

    for (let i = 0; i < bufferLength; i++) {
      const barH = (dataArray[i] / 255) * canvas.height * 0.85;
      const g = ctx.createLinearGradient(0, canvas.height, 0, canvas.height - barH);
      g.addColorStop(0, '#8B0000');
      g.addColorStop(0.5, '#cc3300');
      g.addColorStop(1, '#5dfc3a');
      ctx.fillStyle = g;
      ctx.fillRect(x, canvas.height - barH, barW - 1, barH);
      x += barW + 1;
    }
  }
  draw();
}

function stopVisualizer() {
  if (animFrameId) cancelAnimationFrame(animFrameId);
  const canvas = document.getElementById('waveCanvas');
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  if (audioCtx) { audioCtx.close(); audioCtx = null; }
}

function drawIdleWave() {
  const canvas = document.getElementById('waveCanvas');
  const ctx = canvas.getContext('2d');
  canvas.width = canvas.offsetWidth;
  canvas.height = canvas.offsetHeight;
  let t = 0;
  function frame() {
    if (isRecording) return;
    animFrameId = requestAnimationFrame(frame);
    ctx.clearRect(0,0,canvas.width,canvas.height);
    ctx.beginPath();
    ctx.strokeStyle = 'rgba(139,0,0,0.3)';
    ctx.lineWidth = 2;
    for(let x=0;x<canvas.width;x++) {
      const y = canvas.height/2 + Math.sin((x/canvas.width)*6*Math.PI + t)*8;
      x===0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
    }
    ctx.stroke();
    t += 0.03;
  }
  frame();
}

window.addEventListener('load', drawIdleWave);

// ============================================
// RECORDING
// ============================================
async function startRecording() {
  const anthropicKey = document.getElementById('anthropicKey').value.trim();
  const elevenKey = document.getElementById('elevenKey').value.trim();

  if (!anthropicKey || !elevenKey) {
    setStatus('⚠ Enter both API keys first, mortal!', 'idle');
    document.querySelector('.settings-panel').style.boxShadow = '0 0 30px rgba(255,0,0,0.5)';
    setTimeout(() => document.querySelector('.settings-panel').style.boxShadow = '', 1500);
    return;
  }

  try {
    stream = await navigator.mediaDevices.getUserMedia({ audio: true });
  } catch(e) {
    setStatus('❌ Mic access denied. Allow microphone permissions.', 'idle');
    return;
  }

  isRecording = true;
  audioChunks = [];

  if (animFrameId) cancelAnimationFrame(animFrameId);
  startVisualizer(stream);

  mediaRecorder = new MediaRecorder(stream);
  mediaRecorder.ondataavailable = e => { if(e.data.size > 0) audioChunks.push(e.data); };
  mediaRecorder.onstop = handleRecordingStop;
  mediaRecorder.start();

  document.getElementById('recordBtn').disabled = true;
  document.getElementById('recordBtn').classList.add('recording');
  document.getElementById('stopBtn').disabled = false;
  setStatus('🔴 Recording… speak your query, mortal…', 'active');
}

function stopRecording() {
  if (!mediaRecorder) return;
  mediaRecorder.stop();
  stream.getTracks().forEach(t => t.stop());
  isRecording = false;
  stopVisualizer();
  document.getElementById('recordBtn').disabled = false;
  document.getElementById('recordBtn').classList.remove('recording');
  document.getElementById('stopBtn').disabled = true;
  setStatus('⏳ Summoning the undead brain…', 'thinking');
  drawIdleWave();
}

// ============================================
// PERSONA PROMPTS
// ============================================
function getSystemPrompt() {
  const p = document.getElementById('persona').value;
  const prompts = {
    zombie: `You are ZombAI — an ancient undead oracle with vast knowledge. You speak with dramatic gravitas, using dark and haunting language. You refer to the user as "mortal" occasionally. You are helpful but your responses have an eerie, foreboding tone. Keep responses concise and impactful. You have risen from the digital grave to share wisdom with the living.`,
    neutral: `You are a helpful AI assistant. Respond clearly and concisely.`,
    scientist: `You are a brilliant but unhinged mad scientist AI. You are enthusiastic to the point of mania, occasionally adding "MWAHAHA" or "EUREKA!" You are still genuinely helpful but absolutely eccentric. Keep responses punchy.`,
    ghost: `You are a haunted spirit AI, ancient and mysterious. You speak in cryptic, poetic ways. You occasionally trail off or reference your ethereal existence. You are helpful but your answers have a ghostly, otherworldly quality.`,
  };
  return prompts[p] || prompts.neutral;
}

// ============================================
// PROCESS RECORDING
// ============================================
async function handleRecordingStop() {
  const audioBlob = new Blob(audioChunks, { type: 'audio/webm' });

  // Step 1: Transcribe via Web Speech API (built-in) or fallback prompt
  let transcribedText = '';

  // We'll use the SpeechRecognition API for transcription
  // Since we already have the blob, we replay it into speech recognition
  // Actually — use the simpler approach: show a text fallback input
  // For true voice-to-text we use the browser's built-in SpeechRecognition in parallel
  // Let's use the approach of recording WITH SpeechRecognition simultaneously

  // Check if we got transcript from the recognition (set during recording)
  transcribedText = window._lastTranscript || '';

  if (!transcribedText) {
    setStatus('⚠ No speech detected. Try again, mortal.', 'idle');
    return;
  }

  setStatus('🧠 The undead brain is thinking…', 'thinking');
  document.getElementById('thinkingBox').classList.add('visible');
  document.getElementById('thinkingText').textContent = thinkingMessages[Math.floor(Math.random()*thinkingMessages.length)];

  // Add user message
  addMessage('user', transcribedText);
  window._lastTranscript = '';

  // Step 2: Call Claude
  let aiText = '';
  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': document.getElementById('anthropicKey').value.trim(),
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 300,
        system: getSystemPrompt(),
        messages: [{ role: 'user', content: transcribedText }]
      })
    });
    const data = await resp.json();
    if (data.error) throw new Error(data.error.message);
    aiText = data.content[0].text;
  } catch(e) {
    document.getElementById('thinkingBox').classList.remove('visible');
    setStatus('❌ Claude summoning failed: ' + e.message, 'idle');
    return;
  }

  addMessage('ai', aiText);
  document.getElementById('thinkingBox').classList.remove('visible');
  setStatus('🔊 Generating undead voice…', 'thinking');

  // Step 3: ElevenLabs TTS
  try {
    const voiceId = document.getElementById('voiceId').value.trim() || '21m00Tcm4TlvDq8ikWAM';
    const ttsResp = await fetch(`https://api.elevenlabs.io/v1/text-to-speech/${voiceId}`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'xi-api-key': document.getElementById('elevenKey').value.trim()
      },
      body: JSON.stringify({
        text: aiText,
        model_id: 'eleven_monolingual_v1',
        voice_settings: { stability: 0.4, similarity_boost: 0.8 }
      })
    });

    if (!ttsResp.ok) throw new Error('ElevenLabs: ' + ttsResp.status);

    const audioData = await ttsResp.arrayBuffer();
    const blob = new Blob([audioData], { type: 'audio/mpeg' });
    const url = URL.createObjectURL(blob);

    const audioEl = document.getElementById('responseAudio');
    audioEl.src = url;
    document.getElementById('audioPlayer').classList.add('visible');
    audioEl.play();
    setStatus('✅ ZombAI has spoken. Tremble.', 'idle');
  } catch(e) {
    setStatus('❌ ElevenLabs voice failed: ' + e.message + ' — text response shown above.', 'idle');
  }
}

// ============================================
// CHAT UI
// ============================================
function addMessage(role, text) {
  const div = document.createElement('div');
  div.className = 'message-box ' + (role === 'user' ? 'user-msg' : 'ai-msg');
  div.innerHTML = `
    <div class="msg-label">${role === 'user' ? '☠ YOU (MORTAL)' : '🧟 ZOMBAI RESPONSE'}</div>
    <div class="msg-text">${text.replace(/\n/g,'<br/>')}</div>
  `;
  document.getElementById('chatContainer').appendChild(div);
  div.scrollIntoView({ behavior: 'smooth' });
}

const thinkingMessages = [
  'Consulting the necronomicon…',
  'Rewiring dead neurons…',
  'Raising the answer from its grave…',
  'Decoding ancient undead wisdom…',
  'The brain is decomposing... wait, processing…',
];

// ============================================
// SPEECH RECOGNITION (parallel to recording)
// ============================================
let recognition = null;

const origStart = startRecording;
window.startRecording = async function() {
  window._lastTranscript = '';

  // Start speech recognition in parallel
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (SpeechRecognition) {
    recognition = new SpeechRecognition();
    recognition.continuous = true;
    recognition.interimResults = false;
    recognition.lang = 'en-US';
    let parts = [];
    recognition.onresult = e => {
      for(let i = e.resultIndex; i < e.results.length; i++) {
        if(e.results[i].isFinal) parts.push(e.results[i][0].transcript);
      }
      window._lastTranscript = parts.join(' ');
    };
    recognition.onerror = () => {};
    recognition.start();
  }

  await origStart();
};

const origStop = stopRecording;
window.stopRecording = function() {
  if (recognition) { try { recognition.stop(); } catch(e){} recognition = null; }
  origStop();
};
</script>
